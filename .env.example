# -----------------------------------------------------------------------------
# App / runtime
# -----------------------------------------------------------------------------
# development | production | test | staging
NODE_ENV=development

# Port and HTTP API path (no trailing slash on prefix unless you intend it)
API_PORT=3002
API_PREFIX=/api/v1

# Comma-separated browser origins for production CORS (ignored in non-production for permissive dev CORS)
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,https://yourdomain.com

# Public URLs (used in auth redirects and links)
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Legacy / domain flag used by existing validation (yes | no)
PASSENGERS_ALLOWED=yes

# -----------------------------------------------------------------------------
# Swagger
# -----------------------------------------------------------------------------
# Set to 0 to disable Swagger registration in server bootstrap
SWAGGER_ENABLE=1
SWAGGER_PREFIX=/
SWAGGER_USER=admin
SWAGGER_PASSWORD=admin

# -----------------------------------------------------------------------------
# Health
# -----------------------------------------------------------------------------
HEALTH_TOKEN=

# -----------------------------------------------------------------------------
# Database (Prisma)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://admin:admin@localhost:5433/vocab_db?schema=public

# -----------------------------------------------------------------------------
# Redis (BullMQ, throttler, cache)
# -----------------------------------------------------------------------------
# Option A: single URL (preferred when set)
REDIS_URL=redis://localhost:6379
# Option B: omit REDIS_URL and set host + port (password/db optional)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
REDIS_RETRY_DELAY=100
REDIS_MAX_RETRIES=3
# REDIS_ENABLE_READY_CHECK=true
REDIS_MAX_MEMORY_POLICY=allkeys-lru
REDIS_TTL=3600

# -----------------------------------------------------------------------------
# JWT (signing / verification — see security-utils for usage)
# -----------------------------------------------------------------------------
JWT_SECRET=ThisMustBeChanged
JWT_ISSUER=IssuerApplication

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# -----------------------------------------------------------------------------
# Email (Nodemailer)
# -----------------------------------------------------------------------------
EMAIL_USER=
EMAIL_PASSWORD=

# -----------------------------------------------------------------------------
# Firebase Cloud Messaging (FCM)
# -----------------------------------------------------------------------------
FCM_PROJECT_ID=your-firebase-project-id
FCM_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Use literal \n for newlines when storing in .env
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# -----------------------------------------------------------------------------
# Media / AI (optional API keys — required only for the provider you use)
# -----------------------------------------------------------------------------
CLOUDINARY_URL=cloudinary://<your_api_key>:<your_api_secret>@your_cloud_name
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# Reminders / queues (optional)
# -----------------------------------------------------------------------------
# INSTANCE_ID=my-worker-1
# REMINDER_POLLER_ENABLED=false
# REMINDER_RECONCILIATION_ENABLED=false
