{
    "name": "vocab-management",
    "version": "1.28.1",
    "private": true,
    "engines": {
        "node": ">=20.0.0"
    },
    "scripts": {
        "clean": "rimraf ./dist",
        "start": "node dist/server.js",
        "dev": "env-cmd -f .env nodemon",
        "build": "npm run clean && tsc && tsc-alias -p tsconfig.json",
        "test": "env-cmd -f .env jest --config=jest.json",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "lint": "eslint -c .eslintrc.js --ext .ts --max-warnings 0 \"src/**/*.ts\"",
        "lint:ci": "eslint -c .eslintrc.js --ext .ts --max-warnings 0 --cache --cache-location node_modules/.cache/eslint \"src/**/*.ts\"",
        "lint:fix": "eslint -c .eslintrc.js --ext .ts --fix --max-warnings 0 \"src/**/*.ts\"",
        "format": "prettier --write \"src/**/*.{ts,js,json}\"",
        "format:check": "prettier --check \"src/**/*.{ts,js,json}\"",
        "prepare": "husky install",
        "db:prisma": "prisma migrate dev && prisma generate && prisma db seed",
        "prisma:studio": "prisma studio",
        "db:seed": "prisma db seed",
        "db:reset": "prisma migrate reset",
        "db:migrate": "prisma migrate dev",
        "db:generate": "prisma generate"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    },
    "dependencies": {
        "@bull-board/api": "^6.16.2",
        "@bull-board/express": "^6.16.2",
        "@bull-board/nestjs": "^6.16.2",
        "@google/generative-ai": "^0.24.1",
        "@nestjs/bull": "^11.0.2",
        "@nestjs/common": "^10.3.0",
        "@nestjs/config": "^4.0.2",
        "@nestjs/core": "^10.3.0",
        "@nestjs/platform-express": "^11.1.6",
        "@nestjs/platform-socket.io": "^11.1.6",
        "@nestjs/swagger": "^7.1.17",
        "@nestjs/terminus": "^10.2.0",
        "@nestjs/testing": "^10.3.0",
        "@nestjs/throttler": "^6.5.0",
        "@nestjs/websockets": "^11.1.6",
        "@prisma/client": "^6.11.1",
        "@supabase/supabase-js": "^2.49.10",
        "@types/multer": "^2.0.0",
        "axios": "^1.12.2",
        "bullmq": "^5.56.4",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.0",
        "csv-parser": "^3.2.0",
        "express-basic-auth": "^1.2.1",
        "firebase-admin": "^13.4.0",
        "form-data": "^4.0.5",
        "ioredis": "^5.6.1",
        "joi": "^17.11.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.0.2",
        "nanoid": "^3.3.7",
        "nestjs-throttler-storage-redis": "^0.5.1",
        "nodemailer": "^7.0.5",
        "prisma": "^6.11.1",
        "reflect-metadata": "^0.1.12",
        "rxjs": "^7.8.1",
        "socket.io": "^4.8.1",
        "winston": "^3.11.0"
    },
    "devDependencies": {
        "@types/express": "^5.0.3",
        "@types/form-data": "^2.5.2",
        "@types/jest": "^29.5.11",
        "@types/jsonwebtoken": "^9.0.5",
        "@types/node": "^20.0.0",
        "@types/nodemailer": "^6.4.17",
        "@types/redis-info": "^3.0.3",
        "@types/supertest": "^6.0.2",
        "@typescript-eslint/eslint-plugin": "^6.18.1",
        "@typescript-eslint/parser": "^6.18.1",
        "env-cmd": "^10.1.0",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-prefer-arrow": "^1.2.3",
        "husky": "^8.0.3",
        "jest": "^29.7.0",
        "lint-staged": "^16.4.0",
        "nodemon": "^3.0.2",
        "prettier": "^3.8.2",
        "rimraf": "^5.0.5",
        "supertest": "^6.3.3",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.10",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.3.3"
    },
    "lint-staged": {
        "src/**/*.{ts,js}": [
            "prettier --write",
            "eslint -c .eslintrc.js --max-warnings 0"
        ],
        "*.{json,md}": [
            "prettier --write"
        ]
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@firebase/util",
            "@nestjs/core",
            "@prisma/client",
            "@prisma/engines",
            "msgpackr-extract",
            "prisma",
            "protobufjs"
        ]
    }
}
